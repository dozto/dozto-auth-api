{
	"name": "dozto-auth-api",
	"module": "src/boot.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "NODE_ENV=development bun run src/boot.ts --watch",
		"build": "bun build src/boot.ts --outdir dist --target bun",
		"start": "NODE_ENV=production bun run dist/boot.js",
		"lint": "biome check .",
		"format": "biome check --write .",
		"test:unit": "bun test src",
		"test:intg": "bun test test/intg",
		"test:e2e": "bun test test/e2e",
		"test": "bun run test:unit && bun run test:intg && bun run test:e2e"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/bun": "latest",
		"drizzle-kit": "^0.31.10"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.6",
		"@supabase/supabase-js": "^2.101.1",
		"drizzle-orm": "^0.45.2",
		"eta": "^4.5.1",
		"hono": "^4.12.9",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"postgres": "^3.4.8",
		"standardwebhooks": "^1.0.0",
		"zod": "^4.3.6"
	}
}
