# 运行环境：development 使用 pino-pretty；production / test 使用 JSON 行日志
# NODE_ENV=development

# 日志级别：fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info

# Supabase（服务端使用；勿提交真实密钥到版本库）
SUPABASE_URL=
SUPABASE_ANON_KEY=

# 邮箱密码注册/登录：仅当值为 true 时开启；未设置默认为关闭
AUTH_PASSWORD_ENABLED=true

# HTTP 端口（可选，默认 3000）
PORT=3000

# 对外展示的服务名（可选，默认 dozto-auth-api）
# SERVICE_NAME=dozto-auth-api
